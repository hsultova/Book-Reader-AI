@model BookReaderApp.Models.ViewModels.BookFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="mb-3">
    <label asp-for="Title" class="form-label"></label>
    <input asp-for="Title" class="form-control" />
    <span asp-validation-for="Title" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="AuthorValue" class="form-label">Author</label>
    <select asp-for="AuthorValue" asp-items="ViewBag.Authors" class="form-select" id="AuthorValue">
        <option value=""></option>
    </select>
    <span asp-validation-for="AuthorValue" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="Isbn" class="form-label"></label>
    <input asp-for="Isbn" class="form-control" />
    <span asp-validation-for="Isbn" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="CoverImageUrl" class="form-label"></label>
    <input asp-for="CoverImageUrl" class="form-control" />
    <span asp-validation-for="CoverImageUrl" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="GenreValue" class="form-label">Genre</label>
    <select asp-for="GenreValue" asp-items="ViewBag.Genres" class="form-select" id="GenreValue">
        <option value=""></option>
    </select>
    <span asp-validation-for="GenreValue" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>
