@using BookReaderApp.Models
@using BookReaderApp.Models.ViewModels
@model BookReaderApp.Models.Book
@{
    ViewData["Title"] = Model.Title;
    var canManage = User.IsInRole(AppRoles.Admin)
        || User.IsInRole(AppRoles.Moderator);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var shelfPlacements = ViewData["ShelfPlacements"] as IReadOnlyDictionary<int, UserBook>
        ?? new Dictionary<int, UserBook>();
    var userShelves = ViewData["UserShelves"] as IReadOnlyList<Shelf>
        ?? Array.Empty<Shelf>();
    var ratingSummaries = ViewData["RatingSummaries"] as IReadOnlyDictionary<int, RatingSummary>
        ?? new Dictionary<int, RatingSummary>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var placement = shelfPlacements.TryGetValue(Model.Id, out var ub) ? ub : null;
    var ratingSummary = ratingSummaries.TryGetValue(Model.Id, out var rs) ? rs : null;
    var bookReviews = ViewData["BookReviews"] as IReadOnlyList<Review>
        ?? Array.Empty<Review>();
    var userReview = ViewData["UserReview"] as Review;
    var currentUserId = ViewData["CurrentUserId"] as string;
    var reviewLikeCounts = ViewData["ReviewLikeCounts"] as IReadOnlyDictionary<int, int>
        ?? new Dictionary<int, int>();
    var reviewLikedIds = ViewData["ReviewLikedIds"] as IReadOnlySet<int>
        ?? new HashSet<int>();
    var reviewComments = ViewData["ReviewComments"] as IReadOnlyDictionary<int, IReadOnlyList<ReviewComment>>
        ?? new Dictionary<int, IReadOnlyList<ReviewComment>>();
    var authorFollowerCount = ViewData["AuthorFollowerCount"] is int afc ? afc : 0;
    var isFollowingAuthor = ViewData["IsFollowingAuthor"] is bool ifa && ifa;
    var readingCount = ViewData["ReadingCount"] is int rc ? rc : 0;
    var wantToReadCount = ViewData["WantToReadCount"] is int wc ? wc : 0;
    var readingAvatars = ViewData["ReadingAvatars"] as IReadOnlyList<ReaderAvatar>
        ?? Array.Empty<ReaderAvatar>();
    var wantToReadAvatars = ViewData["WantToReadAvatars"] as IReadOnlyList<ReaderAvatar>
        ?? Array.Empty<ReaderAvatar>();
}

@functions {
    static string Initial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpperInvariant();
}

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" class="book-cover-detail" alt="Cover of @Model.Title" />
        }
        else
        {
            <div class="book-cover-empty book-cover-detail book-cover-detail-empty">No cover</div>
        }
    </div>
    <div class="col-md-8">
        <h1 class="h3">@Model.Title</h1>
        <p class="text-muted">
            by
            @if (Model.Author is not null)
            {
                <a asp-controller="Authors" asp-action="Details" asp-route-id="@Model.Author.Id"
                   class="text-decoration-none fw-semibold">@Model.Author.Name</a>
            }
            else
            {
                <span>Unknown</span>
            }
        </p>
        <div class="mb-3">
            <partial name="_StarRating" model="@(new StarRatingViewModel { BookId = Model.Id, UserRating = placement?.Rating, Summary = ratingSummary, ReturnUrl = returnUrl, CanRate = isAuthenticated && placement is not null })" />
        </div>
        <div class="d-flex flex-wrap gap-4 mb-3 reader-stats">
            <div class="d-flex align-items-center gap-2">
                @if (readingAvatars.Count > 0)
                {
                    <div class="avatar-stack">
                        @foreach (var reader in readingAvatars)
                        {
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@reader.UserId"
                               class="avatar-stack-item" title="@reader.DisplayName">
                                @if (!string.IsNullOrEmpty(reader.ProfilePicturePath))
                                {
                                    <img src="@reader.ProfilePicturePath" alt="@reader.DisplayName" />
                                }
                                else
                                {
                                    <span class="avatar-initial">@Initial(reader.DisplayName)</span>
                                }
                            </a>
                        }
                    </div>
                }
                <div>
                    <span class="fw-semibold">@readingCount.ToString("N0")</span>
                    <span class="text-muted">@(readingCount == 1 ? "person is" : "people are") currently reading</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (wantToReadAvatars.Count > 0)
                {
                    <div class="avatar-stack">
                        @foreach (var reader in wantToReadAvatars)
                        {
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@reader.UserId"
                               class="avatar-stack-item" title="@reader.DisplayName">
                                @if (!string.IsNullOrEmpty(reader.ProfilePicturePath))
                                {
                                    <img src="@reader.ProfilePicturePath" alt="@reader.DisplayName" />
                                }
                                else
                                {
                                    <span class="avatar-initial">@Initial(reader.DisplayName)</span>
                                }
                            </a>
                        }
                    </div>
                }
                <div>
                    <span class="fw-semibold">@wantToReadCount.ToString("N0")</span>
                    <span class="text-muted">@(wantToReadCount == 1 ? "person wants" : "people want") to read</span>
                </div>
            </div>
        </div>
        <dl class="row">
            <dt class="col-sm-3">ISBN</dt>
            <dd class="col-sm-9">@Model.Isbn</dd>
            @if (!string.IsNullOrEmpty(Model.Genre?.Name))
            {
                <dt class="col-sm-3">Genre</dt>
                <dd class="col-sm-9">@Model.Genre.Name</dd>
            }
        </dl>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p>@Model.Description</p>
        }
        <div class="mt-3 d-flex flex-wrap gap-1">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
            @if (isAuthenticated)
            {
                <partial name="_ShelfDropdown" model="@(new ShelfDropdownViewModel { BookId = Model.Id, CurrentStatus = placement?.Status, CurrentShelfId = placement?.ShelfId, CurrentShelfName = placement?.Shelf?.Name, CustomShelves = userShelves, ReturnUrl = returnUrl })" />
            }
            @if (canManage)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
            }
        </div>
    </div>
</div>

@if (Model.Author is not null)
{
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(Model.Author.Photo))
                        {
                            <img src="@Model.Author.Photo" alt="Photo of @Model.Author.Name"
                                 class="rounded-circle flex-shrink-0"
                                 style="width:72px;height:72px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:72px;height:72px;font-size:1.5rem;">
                                @(Model.Author.Name.Trim()[0].ToString().ToUpper())
                            </div>
                        }
                        <div class="flex-grow-1">
                            <h2 class="h5 mb-0">
                                <a asp-controller="Authors" asp-action="Details" asp-route-id="@Model.Author.Id"
                                   class="text-decoration-none">@Model.Author.Name</a>
                            </h2>
                            <div class="text-muted small">
                                @authorFollowerCount @(authorFollowerCount == 1 ? "follower" : "followers")
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Author.Description))
                            {
                                <p class="mb-0 mt-1 small" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                                    @Model.Author.Description
                                </p>
                            }
                        </div>
                        <div class="flex-shrink-0">
                            @if (isAuthenticated)
                            {
                                @if (isFollowingAuthor)
                                {
                                    <form asp-controller="Authors" asp-action="Unfollow" method="post">
                                        <input type="hidden" name="id" value="@Model.Author.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm">Unfollow</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Authors" asp-action="Follow" method="post">
                                        <input type="hidden" name="id" value="@Model.Author.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm">Follow</button>
                                    </form>
                                }
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login"
                                   asp-route-returnUrl="@returnUrl"
                                   class="btn btn-outline-primary btn-sm">Follow</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row mt-4">
    <div class="col-12">
        <partial name="_BookReviews" model="@(new BookReviewsViewModel { BookId = Model.Id, Reviews = bookReviews, UserReview = userReview, CanReview = isAuthenticated && placement is not null, CurrentUserId = currentUserId, ReturnUrl = returnUrl, LikeCounts = reviewLikeCounts, LikedReviewIds = reviewLikedIds, CommentsByReview = reviewComments })" />
    </div>
</div>
