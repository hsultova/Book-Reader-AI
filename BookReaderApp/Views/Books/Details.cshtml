@using BookReaderApp.Models
@using BookReaderApp.Models.ViewModels
@model BookReaderApp.Models.Book
@{
    ViewData["Title"] = Model.Title;
    var canManage = User.IsInRole(AppRoles.Admin)
        || User.IsInRole(AppRoles.Moderator);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var shelfPlacements = ViewData["ShelfPlacements"] as IReadOnlyDictionary<int, UserBook>
        ?? new Dictionary<int, UserBook>();
    var userShelves = ViewData["UserShelves"] as IReadOnlyList<Shelf>
        ?? Array.Empty<Shelf>();
    var ratingSummaries = ViewData["RatingSummaries"] as IReadOnlyDictionary<int, RatingSummary>
        ?? new Dictionary<int, RatingSummary>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var placement = shelfPlacements.TryGetValue(Model.Id, out var ub) ? ub : null;
    var ratingSummary = ratingSummaries.TryGetValue(Model.Id, out var rs) ? rs : null;
    var bookReviews = ViewData["BookReviews"] as IReadOnlyList<Review>
        ?? Array.Empty<Review>();
    var userReview = ViewData["UserReview"] as Review;
    var currentUserId = ViewData["CurrentUserId"] as string;
    var reviewLikeCounts = ViewData["ReviewLikeCounts"] as IReadOnlyDictionary<int, int>
        ?? new Dictionary<int, int>();
    var reviewLikedIds = ViewData["ReviewLikedIds"] as IReadOnlySet<int>
        ?? new HashSet<int>();
    var reviewComments = ViewData["ReviewComments"] as IReadOnlyDictionary<int, IReadOnlyList<ReviewComment>>
        ?? new Dictionary<int, IReadOnlyList<ReviewComment>>();
}

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" class="img-fluid rounded" alt="Cover of @Model.Title" />
        }
        else
        {
            <div class="bg-light border rounded d-flex align-items-center justify-content-center text-muted" style="height: 300px;">No cover</div>
        }
    </div>
    <div class="col-md-8">
        <h1 class="h3">@Model.Title</h1>
        <p class="text-muted">by @Model.Author?.Name</p>
        <div class="mb-3">
            <partial name="_StarRating" model="@(new StarRatingViewModel { BookId = Model.Id, UserRating = placement?.Rating, Summary = ratingSummary, ReturnUrl = returnUrl, CanRate = isAuthenticated && placement is not null })" />
        </div>
        <dl class="row">
            <dt class="col-sm-3">ISBN</dt>
            <dd class="col-sm-9">@Model.Isbn</dd>
            @if (!string.IsNullOrEmpty(Model.Genre?.Name))
            {
                <dt class="col-sm-3">Genre</dt>
                <dd class="col-sm-9">@Model.Genre.Name</dd>
            }
        </dl>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p>@Model.Description</p>
        }
        <div class="mt-3 d-flex flex-wrap gap-1">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
            @if (isAuthenticated)
            {
                <partial name="_ShelfDropdown" model="@(new ShelfDropdownViewModel { BookId = Model.Id, CurrentStatus = placement?.Status, CurrentShelfId = placement?.ShelfId, CurrentShelfName = placement?.Shelf?.Name, CustomShelves = userShelves, ReturnUrl = returnUrl })" />
            }
            @if (canManage)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
            }
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <partial name="_BookReviews" model="@(new BookReviewsViewModel { BookId = Model.Id, Reviews = bookReviews, UserReview = userReview, CanReview = isAuthenticated && placement is not null, CurrentUserId = currentUserId, ReturnUrl = returnUrl, LikeCounts = reviewLikeCounts, LikedReviewIds = reviewLikedIds, CommentsByReview = reviewComments })" />
    </div>
</div>
