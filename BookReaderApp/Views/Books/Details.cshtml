@model BookReaderApp.Models.Book
@{
    ViewData["Title"] = Model.Title;
    var canManage = User.IsInRole(BookReaderApp.Models.AppRoles.Admin)
        || User.IsInRole(BookReaderApp.Models.AppRoles.Moderator);
}

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" class="img-fluid rounded" alt="Cover of @Model.Title" />
        }
        else
        {
            <div class="bg-light border rounded d-flex align-items-center justify-content-center text-muted" style="height: 300px;">No cover</div>
        }
    </div>
    <div class="col-md-8">
        <h1 class="h3">@Model.Title</h1>
        <p class="text-muted">by @Model.Author?.Name</p>
        <dl class="row">
            <dt class="col-sm-3">ISBN</dt>
            <dd class="col-sm-9">@Model.Isbn</dd>
            @if (!string.IsNullOrEmpty(Model.Genre))
            {
                <dt class="col-sm-3">Genre</dt>
                <dd class="col-sm-9">@Model.Genre</dd>
            }
        </dl>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p>@Model.Description</p>
        }
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
            @if (canManage)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
            }
        </div>
    </div>
</div>
