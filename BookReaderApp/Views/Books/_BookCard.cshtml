@using BookReaderApp.Models
@using BookReaderApp.Models.ViewModels
@model BookReaderApp.Models.Book
@{
    var canManage = User.IsInRole(AppRoles.Admin)
        || User.IsInRole(AppRoles.Moderator);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var shelfPlacements = ViewData["ShelfPlacements"] as IReadOnlyDictionary<int, UserBook>
        ?? new Dictionary<int, UserBook>();
    var userShelves = ViewData["UserShelves"] as IReadOnlyList<Shelf>
        ?? Array.Empty<Shelf>();
    var ratingSummaries = ViewData["RatingSummaries"] as IReadOnlyDictionary<int, RatingSummary>
        ?? new Dictionary<int, RatingSummary>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var cardPlacement = shelfPlacements.TryGetValue(Model.Id, out var cardUb) ? cardUb : null;
    var cardSummary = ratingSummaries.TryGetValue(Model.Id, out var cardRs) ? cardRs : null;
}

<div class="card book-card h-100">
    <a asp-action="Details" asp-route-id="@Model.Id" class="book-cover-link">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" class="book-cover" alt="Cover of @Model.Title" loading="lazy" />
        }
        else
        {
            <div class="book-cover-empty">No cover</div>
        }
    </a>
    <div class="card-body d-flex flex-column">
        <h2 class="h5 card-title">
            <a asp-action="Details" asp-route-id="@Model.Id" class="book-title-link">@Model.Title</a>
        </h2>
        <p class="card-text text-muted mb-1">
            @if (Model.Author is not null)
            {
                <a asp-controller="Authors" asp-action="Details" asp-route-id="@Model.Author.Id" class="author-link">@Model.Author.Name</a>
            }
        </p>
        @if (!string.IsNullOrEmpty(Model.Genre?.Name))
        {
            <span class="badge bg-secondary align-self-start mb-2">@Model.Genre.Name</span>
        }
        <div class="mb-2">
            <partial name="_StarRating" model="@(new StarRatingViewModel { BookId = Model.Id, UserRating = cardPlacement?.Rating, Summary = cardSummary, ReturnUrl = returnUrl, CanRate = isAuthenticated && cardPlacement is not null })" />
        </div>
        <div class="mt-auto d-flex flex-wrap gap-1">
            @if (isAuthenticated)
            {
                <partial name="_ShelfDropdown" model="@(new ShelfDropdownViewModel { BookId = Model.Id, CurrentStatus = cardPlacement?.Status, CurrentShelfId = cardPlacement?.ShelfId, CurrentShelfName = cardPlacement?.Shelf?.Name, CustomShelves = userShelves, ReturnUrl = returnUrl })" />
            }
            @if (canManage)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            }
        </div>
    </div>
</div>
