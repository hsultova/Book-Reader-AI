@using BookReaderApp.Models
@using BookReaderApp.Models.ViewModels
@model BookReaderApp.Models.PagedResult<BookReaderApp.Models.Book>
@{
    ViewData["Title"] = "Books";
    var canManage = User.IsInRole(AppRoles.Admin)
        || User.IsInRole(AppRoles.Moderator);
    // Per-book shelf/rating data is read inside the _BookCard partial via ViewData.
    var searchQuery = ViewData["SearchQuery"] as string;
    var recommendations = ViewData["Recommendations"] as IReadOnlyList<RecommendationGroupViewModel>
        ?? Array.Empty<RecommendationGroupViewModel>();
    var aiRecommendations = ViewData["AiRecommendations"] as IReadOnlyList<AiRecommendationViewModel>
        ?? Array.Empty<AiRecommendationViewModel>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Books</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Add book</a>
    }
</div>

<form asp-action="Index" method="get" class="mb-3" role="search">
    <div class="input-group">
        <input type="search" name="q" value="@searchQuery" class="form-control"
               placeholder="Search by title, author, ISBN, or keyword"
               aria-label="Search books" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(searchQuery))
{
    <p class="text-muted">
        @Model.TotalCount result@(Model.TotalCount == 1 ? "" : "s") for "<strong>@searchQuery</strong>"
    </p>
}

@if (aiRecommendations.Count > 0)
{
    <section class="mb-4">
        <h2 class="h5 mb-2">✨ Your AI Librarian suggests</h2>
        <div class="d-flex flex-row overflow-auto gap-3 pb-2 mb-3 recommendation-row">
            @foreach (var rec in aiRecommendations)
            {
                <div class="recommendation-card">
                    <partial name="_BookCard" model="rec.Book" />
                    <p class="small text-muted fst-italic mt-1 mb-0">@rec.Reason</p>
                </div>
            }
        </div>
    </section>
}

@if (recommendations.Count > 0)
{
    <section class="mb-4">
        @foreach (var group in recommendations)
        {
            <h2 class="h5 mb-2">@group.Title</h2>
            <div class="d-flex flex-row overflow-auto gap-3 pb-2 mb-3 recommendation-row">
                @foreach (var book in group.Books)
                {
                    <div class="recommendation-card">
                        <partial name="_BookCard" model="book" />
                    </div>
                }
            </div>
        }
    </section>
}

@if (recommendations.Count > 0 || aiRecommendations.Count > 0)
{
    <h2 class="h5 mb-3 text-muted">All books</h2>
}

@if (Model.TotalCount == 0)
{
    <p class="text-muted">
        @(string.IsNullOrWhiteSpace(searchQuery)
            ? "No books in the catalog yet."
            : "No books match your search.")
    </p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @foreach (var book in Model.Items)
        {
            <div class="col">
                <partial name="_BookCard" model="book" />
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Book pages">
            <ul class="pagination">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@(Model.Page - 1)">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.Page of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
