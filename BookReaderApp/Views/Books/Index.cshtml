@using BookReaderApp.Models
@using BookReaderApp.Models.ViewModels
@model BookReaderApp.Models.PagedResult<BookReaderApp.Models.Book>
@{
    ViewData["Title"] = "Books";
    var canManage = User.IsInRole(AppRoles.Admin)
        || User.IsInRole(AppRoles.Moderator);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var shelfPlacements = ViewData["ShelfPlacements"] as IReadOnlyDictionary<int, UserBook>
        ?? new Dictionary<int, UserBook>();
    var userShelves = ViewData["UserShelves"] as IReadOnlyList<Shelf>
        ?? Array.Empty<Shelf>();
    var ratingSummaries = ViewData["RatingSummaries"] as IReadOnlyDictionary<int, RatingSummary>
        ?? new Dictionary<int, RatingSummary>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var searchQuery = ViewData["SearchQuery"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Books</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Add book</a>
    }
</div>

<form asp-action="Index" method="get" class="mb-3" role="search">
    <div class="input-group">
        <input type="search" name="q" value="@searchQuery" class="form-control"
               placeholder="Search by title, author, ISBN, or keyword"
               aria-label="Search books" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(searchQuery))
{
    <p class="text-muted">
        @Model.TotalCount result@(Model.TotalCount == 1 ? "" : "s") for "<strong>@searchQuery</strong>"
    </p>
}

@if (Model.TotalCount == 0)
{
    <p class="text-muted">
        @(string.IsNullOrWhiteSpace(searchQuery)
            ? "No books in the catalog yet."
            : "No books match your search.")
    </p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @foreach (var book in Model.Items)
        {
            <div class="col">
                <div class="card book-card h-100">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" class="book-cover" alt="Cover of @book.Title" loading="lazy" />
                    }
                    else
                    {
                        <div class="book-cover-empty">No cover</div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 card-title">@book.Title</h2>
                        <p class="card-text text-muted mb-1">@book.Author?.Name</p>
                        @if (!string.IsNullOrEmpty(book.Genre?.Name))
                        {
                            <span class="badge bg-secondary align-self-start mb-2">@book.Genre.Name</span>
                        }
                        @{
                            var cardPlacement = shelfPlacements.TryGetValue(book.Id, out var cardUb) ? cardUb : null;
                            var cardSummary = ratingSummaries.TryGetValue(book.Id, out var cardRs) ? cardRs : null;
                        }
                        <div class="mb-2">
                            <partial name="_StarRating" model="@(new StarRatingViewModel { BookId = book.Id, UserRating = cardPlacement?.Rating, Summary = cardSummary, ReturnUrl = returnUrl, CanRate = isAuthenticated && cardPlacement is not null })" />
                        </div>
                        <div class="mt-auto d-flex flex-wrap gap-1">
                            <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            @if (isAuthenticated)
                            {
                                <partial name="_ShelfDropdown" model="@(new ShelfDropdownViewModel { BookId = book.Id, CurrentStatus = cardPlacement?.Status, CurrentShelfId = cardPlacement?.ShelfId, CurrentShelfName = cardPlacement?.Shelf?.Name, CustomShelves = userShelves, ReturnUrl = returnUrl })" />
                            }
                            @if (canManage)
                            {
                                <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Book pages">
            <ul class="pagination">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@(Model.Page - 1)">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.Page of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-q="@searchQuery" asp-route-page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
