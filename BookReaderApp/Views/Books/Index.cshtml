@model BookReaderApp.Models.PagedResult<BookReaderApp.Models.Book>
@{
    ViewData["Title"] = "Books";
    var canManage = User.IsInRole(BookReaderApp.Models.AppRoles.Admin)
        || User.IsInRole(BookReaderApp.Models.AppRoles.Moderator);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Books</h1>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Add book</a>
    }
</div>

@if (Model.TotalCount == 0)
{
    <p class="text-muted">No books in the catalog yet.</p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @foreach (var book in Model.Items)
        {
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" class="card-img-top" alt="Cover of @book.Title" style="height: 220px; object-fit: cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 card-title">@book.Title</h2>
                        <p class="card-text text-muted mb-1">@book.Author</p>
                        @if (!string.IsNullOrEmpty(book.Genre))
                        {
                            <span class="badge bg-secondary align-self-start mb-2">@book.Genre</span>
                        }
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            @if (canManage)
                            {
                                <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Book pages">
            <ul class="pagination">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.Page of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
