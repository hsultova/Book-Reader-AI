@model BookReaderApp.Models.ViewModels.BookFormViewModel
@{
    ViewData["Title"] = "Edit book";
    var id = (int)ViewData["BookId"]!;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <h1 class="h3 mb-3">Edit book</h1>
        <form asp-action="Edit" asp-route-id="@id" method="post">
            <partial name="_BookForm" model="Model" />
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Details" asp-route-id="@id" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>
    <script>
        new TomSelect('#AuthorValue', {
            create: true,
            createOnBlur: true,
            persist: false,
            placeholder: 'Select or type an author name...',
            maxOptions: null
        });
        new TomSelect('#GenreValue', {
            create: true,
            createOnBlur: true,
            persist: false,
            placeholder: 'Select or type a genre...',
            maxOptions: null
        });
    </script>
}
