@model BookReaderApp.Models.Book
@{
    ViewData["Title"] = "Delete book";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card auth-card">
            <div class="card-body">
                <span class="br-eyebrow auth-eyebrow text-danger">Permanent action</span>
                <h1 class="h3 mb-2">Delete this book?</h1>
                <p class="text-muted">This removes the book from the catalog and everyone's shelves. It can't be undone.</p>
                <dl class="profile-meta my-4">
                    <dt>Title</dt>
                    <dd>@Model.Title</dd>
                    <dt>Author</dt>
                    <dd>@Model.Author?.Name</dd>
                    <dt>ISBN</dt>
                    <dd>@Model.Isbn</dd>
                </dl>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete book</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
