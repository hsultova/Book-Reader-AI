@model IReadOnlyList<BookReaderApp.Models.UserBook>
@{
    ViewData["Title"] = "My Books";
}

<h1 class="h3 mb-3">My Books</h1>

@if (Model.Count == 0)
{
    <p class="text-muted">You haven't added any books to your shelf yet. Browse the <a asp-controller="Books" asp-action="Index">catalog</a> to get started.</p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
        @foreach (var entry in Model)
        {
            var book = entry.Book!;
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" class="card-img-top" alt="Cover of @book.Title" style="height: 220px; object-fit: cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 card-title">@book.Title</h2>
                        <p class="card-text text-muted mb-1">@book.Author?.Name</p>
                        <small class="text-muted mb-2">Added @entry.AddedAt.ToString("d MMM yyyy")</small>
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary mt-auto align-self-start">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
