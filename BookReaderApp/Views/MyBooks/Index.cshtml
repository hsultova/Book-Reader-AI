@using BookReaderApp.Models
@using BookReaderApp.Models.ViewModels
@model MyBooksViewModel
@{
    ViewData["Title"] = "My Books";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<h1 class="h3 mb-3">My Books</h1>

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="list-group">
            <a asp-action="Index"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(Model.SelectedStatus is null && Model.SelectedShelfId is null ? "active" : "")">
                All books
                <span class="badge bg-secondary rounded-pill">@Model.TotalCount</span>
            </a>
            @foreach (var status in Enum.GetValues<ReadingStatus>())
            {
                <a asp-action="Index" asp-route-status="@status"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(Model.SelectedStatus == status ? "active" : "")">
                    @status.DisplayName()
                    <span class="badge bg-secondary rounded-pill">@(Model.Counts.TryGetValue(status, out var c) ? c : 0)</span>
                </a>
            }
        </div>

        @if (Model.CustomShelves.Count > 0)
        {
            <h2 class="h6 text-muted mt-3 mb-2">My shelves</h2>
            <div class="list-group">
                @foreach (var shelf in Model.CustomShelves)
                {
                    var isActive = Model.SelectedShelfId == shelf.Id;
                    <div class="list-group-item d-flex justify-content-between align-items-center gap-2 @(isActive ? "active" : "")">
                        <a asp-action="Index" asp-route-shelfId="@shelf.Id"
                           class="flex-grow-1 text-decoration-none @(isActive ? "text-white" : "text-body")">
                            @shelf.Name
                        </a>
                        <span class="badge bg-secondary rounded-pill">@(Model.ShelfCounts.TryGetValue(shelf.Id, out var sc) ? sc : 0)</span>
                        <form asp-action="DeleteShelf" method="post" class="m-0"
                              onsubmit="return confirm('Delete the shelf &quot;@shelf.Name&quot;? Its books move to Want to Read.');">
                            <input type="hidden" name="shelfId" value="@shelf.Id" />
                            <button type="submit" class="btn btn-sm btn-link p-0 @(isActive ? "text-white" : "text-danger")" title="Delete shelf" aria-label="Delete shelf @shelf.Name">&times;</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-md-9">
        <form asp-action="Index" method="get" class="mb-3" role="search">
            @if (Model.SelectedStatus is not null)
            {
                <input type="hidden" name="status" value="@Model.SelectedStatus" />
            }
            else if (Model.SelectedShelfId is not null)
            {
                <input type="hidden" name="shelfId" value="@Model.SelectedShelfId" />
            }
            <div class="input-group">
                <input type="search" name="q" value="@Model.SearchQuery" class="form-control"
                       placeholder="Search your books by title, author, ISBN, or keyword"
                       aria-label="Search my books" />
                <button type="submit" class="btn btn-outline-primary">Search</button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <a asp-action="Index" asp-route-status="@Model.SelectedStatus" asp-route-shelfId="@Model.SelectedShelfId"
                       class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery) && Model.Books.Count > 0)
        {
            <p class="text-muted">
                @Model.Books.Count result@(Model.Books.Count == 1 ? "" : "s") for "<strong>@Model.SearchQuery</strong>"
            </p>
        }

        @if (Model.Books.Count == 0)
        {
            <p class="text-muted">
                @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <text>No books match "@Model.SearchQuery".</text>
                }
                else if (Model.SelectedStatus is not null)
                {
                    <text>No books on the "@Model.SelectedStatus.Value.DisplayName()" shelf yet.</text>
                }
                else if (Model.SelectedShelfId is not null)
                {
                    var selectedShelf = Model.CustomShelves.FirstOrDefault(s => s.Id == Model.SelectedShelfId);
                    <text>No books on the "@(selectedShelf?.Name)" shelf yet.</text>
                }
                else
                {
                    <text>You haven't added any books to your shelf yet. Browse the <a asp-controller="Books" asp-action="Index">catalog</a> to get started.</text>
                }
            </p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                @foreach (var entry in Model.Books)
                {
                    var book = entry.Book!;
                    var shelfLabel = entry.Shelf?.Name ?? entry.Status?.DisplayName();
                    <div class="col">
                        <div class="card h-100">
                            @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                            {
                                <img src="@book.CoverImageUrl" class="card-img-top" alt="Cover of @book.Title" style="height: 220px; object-fit: cover;" />
                            }
                            <div class="card-body d-flex flex-column">
                                <h2 class="h5 card-title">@book.Title</h2>
                                <p class="card-text text-muted mb-1">@book.Author?.Name</p>
                                @if (!string.IsNullOrEmpty(shelfLabel))
                                {
                                    <span class="badge bg-secondary align-self-start mb-2">@shelfLabel</span>
                                }
                                <small class="text-muted mb-2">Added @entry.AddedAt.ToString("d MMM yyyy")</small>
                                @{
                                    var entrySummary = Model.RatingSummaries.TryGetValue(book.Id, out var entryRs) ? entryRs : null;
                                }
                                <div class="mb-2">
                                    <partial name="_StarRating" model="@(new StarRatingViewModel { BookId = book.Id, UserRating = entry.Rating, Summary = entrySummary, ReturnUrl = returnUrl, CanRate = true })" />
                                </div>
                                <div class="mt-auto d-flex flex-wrap gap-1">
                                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                    <partial name="_ShelfDropdown" model="@(new ShelfDropdownViewModel { BookId = book.Id, CurrentStatus = entry.Status, CurrentShelfId = entry.ShelfId, CurrentShelfName = entry.Shelf?.Name, CustomShelves = Model.CustomShelves, ReturnUrl = returnUrl })" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
