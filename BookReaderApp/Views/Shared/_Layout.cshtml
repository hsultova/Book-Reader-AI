@using Microsoft.AspNetCore.Identity
@using BookReaderApp.Models
@inject BookReaderApp.Messaging.Services.IMessagingService MessagingService
@inject UserManager<ApplicationUser> UserManager
@{
    // Initial unread badge value; live updates arrive over SignalR (see scripts below).
    var unreadCount = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        unreadCount = await MessagingService.GetUnreadCountAsync(UserManager.GetUserId(User)!);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookReaderApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookReaderApp.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BookReaderApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Books" asp-action="Index">Books</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="MyBooks" asp-action="Index">My Books</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" id="communityDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Community
                                    <span id="nav-unread-badge"
                                          class="badge bg-primary rounded-pill @(unreadCount > 0 ? "" : "d-none")">@unreadCount</span>
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="communityDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Messages" asp-action="Index">Messages</a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BookReaderApp
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- One shared chat connection per page: keeps the unread badge live everywhere and
             is reused by the thread view (window.chatConnection) for incoming messages. -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
        <script>
            (function () {
                const badge = document.getElementById("nav-unread-badge");
                function renderBadge(count) {
                    if (!badge) return;
                    badge.textContent = count;
                    badge.classList.toggle("d-none", count <= 0);
                }

                window.chatConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/chat")
                    .withAutomaticReconnect()
                    .build();
                window.chatConnection.on("UnreadCountChanged", renderBadge);
                window.chatConnection.start().catch(err => console.error(err));
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
