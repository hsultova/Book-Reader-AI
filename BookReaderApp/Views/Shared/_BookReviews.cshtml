@model BookReaderApp.Models.ViewModels.BookReviewsViewModel

<section class="book-reviews mt-4">
    <h2 class="h5">Reviews</h2>

    @* The signed-in user's write/edit form, only for books on their shelf. *@
    @if (Model.CanReview)
    {
        var editing = Model.UserReview is not null;
        <div class="card mb-3">
            <div class="card-body">
                <form asp-controller="Reviews" asp-action="Save" method="post" class="m-0">
                    <input type="hidden" name="bookId" value="@Model.BookId" />
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <label class="form-label fw-semibold" for="review-text">
                        @(editing ? "Edit your review" : "Write a review")
                    </label>
                    <textarea id="review-text" name="text" class="form-control" rows="4"
                              placeholder="Share your thoughts about this book…" required>@Model.UserReview?.Text</textarea>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="containsSpoilers" value="true"
                               id="review-spoilers" @(Model.UserReview?.ContainsSpoilers == true ? "checked" : "") />
                        <label class="form-check-label" for="review-spoilers">Contains spoilers</label>
                    </div>
                    <div class="mt-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            @(editing ? "Update review" : "Post review")
                        </button>
                    </div>
                </form>
                @if (editing)
                {
                    <form asp-controller="Reviews" asp-action="Delete" method="post" class="mt-2">
                        <input type="hidden" name="bookId" value="@Model.BookId" />
                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete review</button>
                    </form>
                }
            </div>
        </div>
    }

    @* Community reviews, shown to everyone. *@
    @if (Model.Reviews.Count == 0)
    {
        <p class="text-muted">No reviews yet.</p>
    }
    else
    {
        var isAuthenticated = Model.CurrentUserId is not null;
        foreach (var review in Model.Reviews)
        {
            var isMine = isAuthenticated && review.UserId == Model.CurrentUserId;
            var likeCount = Model.LikeCounts.TryGetValue(review.Id, out var lc) ? lc : 0;
            var likedByMe = Model.LikedReviewIds.Contains(review.Id);
            var comments = Model.CommentsByReview.TryGetValue(review.Id, out var cs)
                ? cs : Array.Empty<ReviewComment>();
            // Logged-in readers may like/comment on other readers' reviews (any book, not just shelved).
            var canInteract = isAuthenticated && !isMine;
            <div class="card mb-2">
                <div class="card-body">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                        @if (review.User is not null)
                        {
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@review.User.Id"
                               class="fw-semibold text-decoration-none">@review.User.DisplayName</a>
                        }
                        else
                        {
                            <span class="fw-semibold">Anonymous</span>
                        }
                        @if (isMine)
                        {
                            <span class="badge bg-secondary">You</span>
                        }
                        @if (review.ContainsSpoilers)
                        {
                            <span class="badge bg-warning text-dark">Spoiler</span>
                        }
                        <span class="small text-muted ms-auto">@review.CreatedAt.ToString("d MMM yyyy")</span>
                    </div>
                    @if (review.ContainsSpoilers)
                    {
                        <details>
                            <summary class="text-muted" style="cursor: pointer;">Spoiler — click to reveal</summary>
                            <p class="mb-0 mt-2" style="white-space: pre-wrap;">@review.Text</p>
                        </details>
                    }
                    else
                    {
                        <p class="mb-0" style="white-space: pre-wrap;">@review.Text</p>
                    }

                    @* Like control. Logged-in non-authors get a toggle button; everyone else sees a static count. *@
                    <div class="mt-2 d-flex align-items-center gap-2">
                        @if (canInteract)
                        {
                            <form asp-controller="Reviews" asp-action="ToggleLike" method="post" class="m-0">
                                <input type="hidden" name="reviewId" value="@review.Id" />
                                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                <button type="submit"
                                        class="btn btn-link p-0 lh-1 text-decoration-none @(likedByMe ? "text-danger" : "text-secondary")"
                                        title="@(likedByMe ? "Unlike this review" : "Like this review")"
                                        aria-label="@(likedByMe ? "Unlike this review" : "Like this review")">
                                    @(likedByMe ? "♥" : "♡") <span class="small">@likeCount</span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-secondary lh-1" title="@likeCount like@(likeCount == 1 ? "" : "s")">
                                ♥ <span class="small">@likeCount</span>
                            </span>
                        }
                    </div>

                    @* Comments thread. *@
                    @if (comments.Count > 0)
                    {
                        <ul class="list-unstyled mt-3 mb-0 border-top pt-2">
                            @foreach (var comment in comments)
                            {
                                var commentIsMine = isAuthenticated && comment.UserId == Model.CurrentUserId;
                                <li class="mb-2">
                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                        @if (comment.User is not null)
                                        {
                                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@comment.User.Id"
                                               class="fw-semibold small text-decoration-none">@comment.User.DisplayName</a>
                                        }
                                        else
                                        {
                                            <span class="fw-semibold small">Anonymous</span>
                                        }
                                        <span class="small text-muted">@comment.CreatedAt.ToString("d MMM yyyy")</span>
                                        @if (commentIsMine)
                                        {
                                            <form asp-controller="Reviews" asp-action="DeleteComment" method="post" class="m-0 ms-auto">
                                                <input type="hidden" name="commentId" value="@comment.Id" />
                                                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                                <button type="submit" class="btn btn-link btn-sm p-0 text-decoration-none text-danger"
                                                        title="Delete comment">Delete</button>
                                            </form>
                                        }
                                    </div>
                                    <p class="mb-0 small" style="white-space: pre-wrap;">@comment.Text</p>
                                </li>
                            }
                        </ul>
                    }

                    @* Add-comment box, only for logged-in readers commenting on others' reviews. *@
                    @if (canInteract)
                    {
                        <form asp-controller="Reviews" asp-action="AddComment" method="post" class="mt-2">
                            <input type="hidden" name="reviewId" value="@review.Id" />
                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                            <div class="input-group input-group-sm">
                                <input type="text" name="text" class="form-control"
                                       placeholder="Add a comment…" required aria-label="Add a comment" />
                                <button type="submit" class="btn btn-outline-primary">Comment</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        }
    }
</section>
