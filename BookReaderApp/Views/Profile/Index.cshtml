@model BookReaderApp.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = Model.DisplayName + " — Profile";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card profile-card">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicturePath))
                    {
                        <img src="@Model.ProfilePicturePath" alt="@Model.DisplayName"
                             class="rounded-circle object-fit-cover profile-avatar flex-shrink-0" width="96" height="96" />
                    }
                    else
                    {
                        <div class="rounded-circle profile-avatar-fallback d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:96px;height:96px;font-size:2rem;background-color:var(--br-forest);color:#F4ECD8;">
                            @(string.IsNullOrWhiteSpace(Model.DisplayName) ? "?" : Model.DisplayName.Trim()[0].ToString().ToUpper())
                        </div>
                    }
                    <div>
                        <h1 class="h3 profile-name">@Model.DisplayName</h1>
                        <small class="text-muted">Member since @Model.CreatedAt.ToString("MMMM yyyy")</small>
                    </div>
                </div>

                <hr class="profile-divider" />

                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <span class="br-eyebrow profile-section-label">About me</span>
                    <p class="profile-bio">@Model.Bio</p>
                }

                @if (!string.IsNullOrWhiteSpace(Model.FavoriteGenre))
                {
                    <dl class="profile-meta">
                        <dt>Favorite genre</dt>
                        <dd>@Model.FavoriteGenre</dd>
                    </dl>
                }

                @{
                    var challenge = Model.Challenge;
                }
                <section class="reading-challenge mt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="br-eyebrow profile-section-label">@challenge.Year Reading Challenge</span>
                        @if (challenge.IsOwnProfile)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="modal" data-bs-target="#editGoalModal">
                                @(challenge.Goal.HasValue ? "Edit goal" : "Set a goal")
                            </button>
                        }
                    </div>

                    @if (TempData["GoalError"] is string goalError)
                    {
                        <div class="alert alert-danger mt-2 mb-0 py-2" role="alert">@goalError</div>
                    }

                    @if (challenge.Goal is > 0)
                    {
                        <div class="d-flex justify-content-between small text-muted mt-2">
                            <span>@challenge.FinishedCount of @challenge.Goal books</span>
                            <span>@challenge.PercentComplete%</span>
                        </div>
                        <div class="progress" role="progressbar"
                             aria-valuenow="@challenge.FinishedCount" aria-valuemin="0" aria-valuemax="@challenge.Goal">
                            <div class="progress-bar bg-success" style="width:@(challenge.PercentComplete)%"></div>
                        </div>
                        @if (challenge.FinishedCount >= challenge.Goal)
                        {
                            <p class="text-success small mt-2 mb-0">
                                <i class="bi bi-stars"></i> Goal reached — congratulations!
                            </p>
                        }
                    }
                    else if (challenge.IsOwnProfile)
                    {
                        <p class="text-muted small mt-2 mb-0">Set a goal to start your @challenge.Year reading challenge.</p>
                    }
                    else
                    {
                        <p class="text-muted small mt-2 mb-0">No reading goal set for @challenge.Year.</p>
                    }

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        @foreach (var milestone in challenge.Milestones)
                        {
                            <span class="badge @(milestone.Unlocked ? "text-bg-success" : "text-bg-light text-muted border")"
                                  title="@(milestone.Unlocked ? "Unlocked" : "Locked")">
                                <i class="bi @(milestone.Unlocked ? "bi-trophy-fill" : "bi-trophy")"></i>
                                @milestone.Count book@(milestone.Count == 1 ? "" : "s")
                            </span>
                        }
                    </div>
                </section>

                @if (Model.IsOwnProfile)
                {
                    <a asp-action="Settings" class="btn btn-outline-primary mt-3">Edit profile</a>
                }
                else
                {
                    <div class="mt-3 d-flex gap-2">
                        <div class="btn-group">
                            <button type="button" class="btn btn-primary dropdown-toggle"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                @(Model.IsFollowing ? "Following" : "Follow")
                            </button>
                            <ul class="dropdown-menu">
                                @* Follow is a lightweight, one-way relationship. *@
                                <li>
                                    @if (Model.IsFollowing)
                                    {
                                        <form asp-controller="Follow" asp-action="Unfollow" method="post">
                                            <input type="hidden" name="id" value="@Model.UserId" />
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-person-dash"></i> Unfollow
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="Follow" asp-action="Follow" method="post">
                                            <input type="hidden" name="id" value="@Model.UserId" />
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-person-plus"></i> Follow
                                            </button>
                                        </form>
                                    }
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                @* Friending is mutual and unlocks messaging. *@
                                @switch (Model.FriendState)
                                {
                                    case BookReaderApp.Models.ViewModels.FriendState.None:
                                        <li>
                                            <form asp-controller="Friends" asp-action="Send" method="post">
                                                <input type="hidden" name="id" value="@Model.UserId" />
                                                <button type="submit" class="dropdown-item">
                                                    <i class="bi bi-person-plus"></i> Add friend
                                                </button>
                                            </form>
                                        </li>
                                        break;
                                    case BookReaderApp.Models.ViewModels.FriendState.OutgoingPending:
                                        <li><span class="dropdown-item disabled">Friend request sent</span></li>
                                        break;
                                    case BookReaderApp.Models.ViewModels.FriendState.IncomingPending:
                                        <li>
                                            <form asp-controller="Friends" asp-action="Accept" method="post">
                                                <input type="hidden" name="id" value="@Model.PendingRequestId" />
                                                <button type="submit" class="dropdown-item">
                                                    <i class="bi bi-check-lg"></i> Accept friend request
                                                </button>
                                            </form>
                                        </li>
                                        <li>
                                            <form asp-controller="Friends" asp-action="Reject" method="post">
                                                <input type="hidden" name="id" value="@Model.PendingRequestId" />
                                                <button type="submit" class="dropdown-item">Reject friend request</button>
                                            </form>
                                        </li>
                                        break;
                                    case BookReaderApp.Models.ViewModels.FriendState.Friends:
                                        <li>
                                            <form asp-controller="Friends" asp-action="Unfriend" method="post">
                                                <input type="hidden" name="id" value="@Model.UserId" />
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="bi bi-person-dash"></i> Remove friend
                                                </button>
                                            </form>
                                        </li>
                                        break;
                                }
                            </ul>
                        </div>

                        @if (Model.FriendState == BookReaderApp.Models.ViewModels.FriendState.Friends)
                        {
                            <form asp-controller="Messages" asp-action="Open" method="post">
                                <input type="hidden" name="id" value="@Model.UserId" />
                                <button type="submit" class="btn btn-outline-primary">Message</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.Challenge.IsOwnProfile)
{
    <div class="modal fade" id="editGoalModal" tabindex="-1" aria-labelledby="editGoalModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="UpdateGoal" method="post" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editGoalModalLabel">@Model.Challenge.Year Reading Challenge</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label for="readingGoal" class="form-label">How many books do you want to read this year?</label>
                    <input type="number" class="form-control" id="readingGoal" name="readingGoal"
                           min="0" max="1000" value="@Model.Challenge.Goal" placeholder="e.g. 24" />
                    <div class="form-text">Set to 0 to clear your goal. You can adjust this any time.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save goal</button>
                </div>
            </form>
        </div>
    </div>
}
