@model BookReaderApp.Models.ViewModels.MessagesViewModel
@{
    ViewData["Title"] = "Messages";
}

@functions {
    // Avatar fallback initial, mirroring the Friends/profile pattern.
    static string Initial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpper();
}

<h1 class="h3 mb-4">Messages</h1>

@if (Model.Conversations.Count == 0)
{
    <p class="text-muted">
        You have no conversations yet. Visit a <a asp-controller="Friends" asp-action="Index">friend's</a>
        profile and choose &ldquo;Message&rdquo; to start one.
    </p>
}
else
{
    <ul class="list-group">
        @foreach (var c in Model.Conversations)
        {
            <li class="list-group-item">
                <a asp-action="Thread" asp-route-id="@c.ConversationId"
                   class="d-flex align-items-center gap-3 text-decoration-none text-reset">
                    @if (!string.IsNullOrEmpty(c.OtherProfilePicturePath))
                    {
                        <img src="@c.OtherProfilePicturePath" alt="@c.OtherDisplayName"
                             class="rounded-circle object-fit-cover" width="48" height="48" />
                    }
                    else
                    {
                        <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                              style="width:48px;height:48px;">@Initial(c.OtherDisplayName)</span>
                    }
                    <span class="me-auto">
                        <span class="d-block fw-semibold">@c.OtherDisplayName</span>
                        <span class="d-block text-muted small text-truncate" style="max-width:32rem;">
                            @if (c.LastMessageFromMe)
                            {
                                <span class="text-secondary">You: </span>
                            }
                            @(c.LastMessagePreview ?? "No messages yet")
                        </span>
                    </span>
                    @if (c.UnreadCount > 0)
                    {
                        <span class="badge bg-primary rounded-pill">@c.UnreadCount</span>
                    }
                </a>
            </li>
        }
    </ul>
}
