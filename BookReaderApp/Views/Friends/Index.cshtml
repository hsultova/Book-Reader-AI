@model BookReaderApp.Models.ViewModels.FriendsViewModel
@{
    ViewData["Title"] = "Friends";
}

@functions {
    // Avatar markup shared by every list row (mirrors the profile/nav pattern).
    static string Initial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpper();
}

<h1 class="h3 mb-4">Friends</h1>

<section class="mb-5">
    <h2 class="h5 mb-3">Find people</h2>

    <form asp-action="Index" method="get" class="mb-3" role="search">
        <div class="input-group">
            <input type="search" name="q" value="@Model.SearchQuery" class="form-control"
                   placeholder="Search all users by name" aria-label="Search users" />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
    {
        @if (Model.SearchResults.Count == 0)
        {
            <p class="text-muted">No users match &ldquo;@Model.SearchQuery&rdquo;.</p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var user in Model.SearchResults)
                {
                    <li class="list-group-item d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(user.ProfilePicturePath))
                        {
                            <img src="@user.ProfilePicturePath" alt="@user.DisplayName"
                                 class="rounded-circle object-fit-cover" width="40" height="40" />
                        }
                        else
                        {
                            <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                                  style="width:40px;height:40px;">@Initial(user.DisplayName)</span>
                        }
                        <a asp-controller="Profile" asp-action="Index" asp-route-id="@user.UserId"
                           class="text-decoration-none me-auto">@user.DisplayName</a>
                        @switch (user.State)
                        {
                            case BookReaderApp.Models.ViewModels.FriendState.None:
                                <form asp-controller="Friends" asp-action="Send" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm btn-primary">Add friend</button>
                                </form>
                                break;
                            case BookReaderApp.Models.ViewModels.FriendState.OutgoingPending:
                                <form asp-controller="Friends" asp-action="Cancel" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.RequestId" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Cancel friend request</button>
                                </form>
                                break;
                            case BookReaderApp.Models.ViewModels.FriendState.IncomingPending:
                                <form asp-controller="Friends" asp-action="Accept" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.RequestId" />
                                    <button type="submit" class="btn btn-sm btn-success">Accept</button>
                                </form>
                                <form asp-controller="Friends" asp-action="Reject" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.RequestId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                </form>
                                break;
                            case BookReaderApp.Models.ViewModels.FriendState.Friends:
                                <span class="badge bg-success">Friends</span>
                                break;
                        }
                    </li>
                }
            </ul>
        }
    }
</section>

<section class="mb-5">
    <h2 class="h5 mb-3">My friends</h2>
    @if (Model.Friends.Count == 0)
    {
        <p class="text-muted">You haven't added any friends yet.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var friend in Model.Friends)
            {
                <li class="list-group-item d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(friend.ProfilePicturePath))
                    {
                        <img src="@friend.ProfilePicturePath" alt="@friend.DisplayName"
                             class="rounded-circle object-fit-cover" width="40" height="40" />
                    }
                    else
                    {
                        <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                              style="width:40px;height:40px;">@Initial(friend.DisplayName)</span>
                    }
                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@friend.UserId"
                       class="text-decoration-none">@friend.DisplayName</a>
                </li>
            }
        </ul>
    }
</section>

<section class="mb-5">
    <h2 class="h5 mb-3">Following</h2>
    @if (Model.Following.Count == 0)
    {
        <p class="text-muted">You aren't following anyone yet.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var followee in Model.Following)
            {
                <li class="list-group-item d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(followee.ProfilePicturePath))
                    {
                        <img src="@followee.ProfilePicturePath" alt="@followee.DisplayName"
                             class="rounded-circle object-fit-cover" width="40" height="40" />
                    }
                    else
                    {
                        <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                              style="width:40px;height:40px;">@Initial(followee.DisplayName)</span>
                    }
                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@followee.UserId"
                       class="text-decoration-none me-auto">@followee.DisplayName</a>
                    <form asp-controller="Follow" asp-action="Unfollow" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@followee.UserId" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("Index")" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Unfollow</button>
                    </form>
                </li>
            }
        </ul>
    }
</section>

<section class="mb-5">
    <h2 class="h5 mb-3">Requests received</h2>
    @if (Model.IncomingRequests.Count == 0)
    {
        <p class="text-muted">No pending requests.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var req in Model.IncomingRequests)
            {
                <li class="list-group-item d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(req.ProfilePicturePath))
                    {
                        <img src="@req.ProfilePicturePath" alt="@req.DisplayName"
                             class="rounded-circle object-fit-cover" width="40" height="40" />
                    }
                    else
                    {
                        <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                              style="width:40px;height:40px;">@Initial(req.DisplayName)</span>
                    }
                    <a asp-controller="Profile" asp-action="Index" asp-route-id="@req.UserId"
                       class="text-decoration-none me-auto">@req.DisplayName</a>
                    <form asp-controller="Friends" asp-action="Accept" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@req.RequestId" />
                        <button type="submit" class="btn btn-sm btn-success">Accept</button>
                    </form>
                    <form asp-controller="Friends" asp-action="Reject" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@req.RequestId" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                    </form>
                </li>
            }
        </ul>
    }
</section>
